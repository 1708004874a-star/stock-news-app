# ----------------------------------------------------------------------------
# stock-news-app environment template
# Copy this file to `.env.local` and fill in your own values. DO NOT commit
# `.env.local` — it is git-ignored.
# ----------------------------------------------------------------------------

# Postgres connection string. On Vercel use the Vercel Postgres / Neon URL.
# Locally you can point at a Docker Postgres or a remote dev database.
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DBNAME"

# Finnhub API key — used for company news and quote fallback.
# Get one at: https://finnhub.io/register  (free tier: 60 req/min)
FINNHUB_API_KEY=""

# DeepSeek API key — used for the AI relevance filter and Chinese summaries.
# Get one at: https://platform.deepseek.com/  (cheap, OpenAI-compatible)
# If left empty, the app falls back to keyword-grouped news without AI summaries.
DEEPSEEK_API_KEY=""

# Shared secret protecting the cron endpoint at /api/cron/fetch-news.
# Pick any long random string; Vercel Cron must send it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=""
